# ATLAS Corporation — environment template.
# Copy this file to .env (which is gitignored) and fill in real values.
# Nothing secret is ever committed. The brain never signs; secrets reach only the signer/worker.

# ── LLM brain (the ONLY value needed to start ATLAS in dry-run) ──
ANTHROPIC_API_KEY=

# ── OKX rail — SA API for x402 settlement (crown jewels; add only when wiring the rail) ──
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── Virtuals rail (added at v1.5) ──
GAME_API_KEY=

# ── Durable event log ──
DATABASE_URL=
